# Raw/original photos — NEVER commit these to a public repo.
# Put your original images here while encrypting; only secret.enc.json (encrypted) gets committed.
private/
photos/
originals/
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.heic

# The encrypted bundle IS safe to commit (it's useless without the passphrase)
!secret.enc.json

# Site design assets (favicon, PWA icons, share image) ARE meant to be public
!assets/
!assets/**

# Node modules (only used locally to generate images via sharp)
node_modules/

# Local-only content generators — contain PLAINTEXT private letter/passphrase.
# NEVER commit these. Only the encrypted secret.enc.json is committed.
*.local.js
